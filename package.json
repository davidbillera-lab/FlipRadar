{
  "name": "flipradar",
  "version": "1.0.0",
  "description": "Resale arbitrage agent — scrapes Facebook Marketplace and Craigslist, looks up eBay sold comps, scores deals by ROI, and sends Telegram alerts.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "start": "tsx server/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx server/db/migrate.ts",
    "score-deals": "tsx server/jobs/score-deals.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@trpc/server": "^11.0.0",
    "better-sqlite3": "^11.5.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "express": "^4.21.1",
    "node-cron": "^3.0.3",
    "superjson": "^2.2.1",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
