# --- Server ---
PORT=3000
DATABASE_PATH=./data/flipradar.db

# --- Anthropic (LLM product identification) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- eBay Browse API ---
# Get these from https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US

# --- Telegram alerts (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Google Maps (optional) ---
# Used for geocoding garage sale addresses → lat/lng so they appear on the map.
# Get a key at https://console.cloud.google.com/google/maps-apis/credentials
# Enable: Geocoding API (and Maps Static API if you want server-rendered map tiles)
GOOGLE_MAPS_API_KEY=

# --- Scraper ---
# City to search for garage sales / marketplace listings
SCRAPER_CITY=denver
# Cron schedule for the auto-scraper (default: every 30 minutes)
SCRAPER_CRON=*/30 * * * *

# --- Scheduled task script ---
SCHEDULED_TASK_ENDPOINT_BASE=http://localhost:3000
SCHEDULED_TASK_COOKIE=
